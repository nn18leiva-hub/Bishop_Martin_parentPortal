{
	"info": {
		"name": "Bishop Martin Parent Portal API (V2)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register Parent",
					"request": {
						"method": "POST",
						"header": [ { "key": "Content-Type", "value": "application/json" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"full_name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"600-1234\",\n  \"password\": \"password123\",\n  \"user_type\": \"parent\",\n  \"dob\": \"1980-01-01\"\n}"
						},
						"url": "http://localhost:3000/auth/register"
					}
				},
                {
					"name": "Register Past Student",
					"request": {
						"method": "POST",
						"header": [ { "key": "Content-Type", "value": "application/json" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"full_name\": \"Jane Alum\",\n  \"email\": \"jane@example.com\",\n  \"phone\": \"600-5678\",\n  \"password\": \"password123\",\n  \"user_type\": \"past_student\",\n  \"dob\": \"2000-05-15\"\n}"
						},
						"url": "http://localhost:3000/auth/register"
					}
				},
				{
					"name": "Login (Universal)",
					"request": {
						"method": "POST",
						"header": [ { "key": "Content-Type", "value": "application/json" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
						},
						"url": "http://localhost:3000/auth/login"
					}
				}
			]
		},
		{
			"name": "Requester Actions (Parents / Students)",
			"item": [
				{
					"name": "Get Profile",
					"request": {
						"method": "GET",
						"header": [ { "key": "Authorization", "value": "Bearer REPLACE_WITH_TOKEN" } ],
						"url": "http://localhost:3000/parent/profile"
					}
				},
				{
					"name": "My Document Requests",
					"request": {
						"method": "GET",
						"header": [ { "key": "Authorization", "value": "Bearer REPLACE_WITH_TOKEN" } ],
						"url": "http://localhost:3000/requests/my-requests"
					}
				},
                {
					"name": "Create Auto-Generated Slip",
					"request": {
						"method": "POST",
						"header": [ { "key": "Authorization", "value": "Bearer REPLACE_WITH_TOKEN" } ],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "document_type_id", "value": "1", "type": "text" },
								{ "key": "student_bemis_id", "value": "B12345", "type": "text" },
								{ "key": "student_full_name", "value": "Jimmy Doe", "type": "text" },
								{ "key": "student_graduation_year_or_years_attended", "value": "2023", "type": "text" },
								{ "key": "delivery_method", "value": "emailed", "type": "text" },
								{ "key": "form_data", "value": "{\"reason\":\"Dentist Appointment\"}", "type": "text" },
								{ "key": "signature_image", "type": "file", "src": "path_to_dummy_image.png" }
							]
						},
						"url": "http://localhost:3000/requests/create"
					}
				}
			]
		},
		{
			"name": "Staff Actions (Admins & Viewers)",
			"item": [
				{
					"name": "Get All Document Requests",
					"request": {
						"method": "GET",
						"header": [ { "key": "Authorization", "value": "Bearer REPLACE_WITH_STAFF_TOKEN" } ],
						"url": "http://localhost:3000/staff/requests"
					}
				},
                {
					"name": "Update Request Status",
					"request": {
						"method": "PATCH",
						"header": [ 
                            { "key": "Authorization", "value": "Bearer REPLACE_WITH_STAFF_TOKEN" },
                            { "key": "Content-Type", "value": "application/json" }
                        ],
                        "body": {
							"mode": "raw",
							"raw": "{\n  \"request_id\": 1,\n  \"status\": \"ready_for_pickup\"\n}"
						},
						"url": "http://localhost:3000/staff/requests/status"
					}
				}
			]
		},
        {
			"name": "Super Admin Actions",
			"item": [
				{
					"name": "Get Staff Directory",
					"request": {
						"method": "GET",
						"header": [ { "key": "Authorization", "value": "Bearer REPLACE_WITH_SUPER_ADMIN_TOKEN" } ],
						"url": "http://localhost:3000/superadmin/staff"
					}
				},
                {
					"name": "Create Staff Account",
					"request": {
						"method": "POST",
						"header": [ 
                            { "key": "Authorization", "value": "Bearer REPLACE_WITH_SUPER_ADMIN_TOKEN" },
                            { "key": "Content-Type", "value": "application/json" }
                        ],
                        "body": {
							"mode": "raw",
							"raw": "{\n  \"full_name\": \"New Secretary\",\n  \"email\": \"secretary@bmhs.edu.bz\",\n  \"password\": \"temp123\",\n  \"role\": \"admin\"\n}"
						},
						"url": "http://localhost:3000/superadmin/staff"
					}
				}
			]
		}
	]
}
